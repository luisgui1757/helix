{
  "models": [
    {
      "id": "azure-foundry/<deployment-name>",
      "provider": "openai-compatible",
      "baseUrl": "https://<resource-name>.<region>.models.ai.azure.com",
      "api": "openai-chat-completions",
      "apiKeyEnv": "AZURE_FOUNDRY_KEY",
      "headers": {
        "api-version": "<api-version>"
      },
      "compat": {
        "supportsStreaming": true,
        "supportsTools": false
      }
    }
  ]
}
