{
  "schema_version": 2,
  "configs": [
    {
      "id": "mock-core-loop",
      "description": "No-live bounded implementation loop over a synthetic/public worktree fixture.",
      "chain": "full-cycle",
      "role_matrix": "mock-core-loop",
      "assignments": {
        "plan": { "kind": "composite", "preset": "overlord" },
        "implement": { "kind": "composite", "preset": "daily" }
      },
      "default_assignment": { "kind": "composite", "preset": "daily" },
      "max_iterations": 5,
      "objective_gate": {
        "type": "file-contains",
        "path": "proposal.txt",
        "contains": "HELIX_LOOP_PASS"
      },
      "parallel": {
        "max_concurrency": 2
      },
      "run_target": {
        "repo": "self"
      },
      "input_refs": [
        {
          "kind": "local-ref",
          "value": "local-ref:input/mock-core-loop",
          "algorithm": null
        }
      ],
      "claims_ref": "local-ref:claims/mock-core-loop",
      "evidence_ref": "local-ref:evidence/mock-core-loop"
    }
  ]
}
