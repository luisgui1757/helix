{
  "name": "pi-helix",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Native multi-model team workflows for the Pi coding agent.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luisgui1757/helix.git"
  },
  "homepage": "https://github.com/luisgui1757/helix#readme",
  "bugs": {
    "url": "https://github.com/luisgui1757/helix/issues"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "multi-agent",
    "coding-agent"
  ],
  "type": "module",
  "files": [
    "README.md",
    "LICENSE",
    "extensions",
    "dispatch/config",
    "dispatch/lib",
    "docs/manual.md",
    "docs/workflows.md",
    "tools/loop/helix-task-loop.mjs",
    "tools/research/helix-research.mjs"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check:resources": "node tools/check-helix-resources.mjs",
    "check:docs-truth": "node tools/ci/docs-truth-check.mjs",
    "check:public-safety-diff": "node tools/ci/public-safety-diff-scan.mjs --mode diff",
    "check:no-live-egress": "node tools/ci/no-live-egress-check.mjs",
    "test": "node --test tests/*.test.mjs && bash tools/worktree/selftest.sh && bash tools/loop/selftest.sh"
  },
  "pi": {
    "extensions": [
      "./extensions/helix-fence.ts",
      "./extensions/helix-answer.ts",
      "./extensions/helix-command.ts"
    ]
  }
}
