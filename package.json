{
  "name": "pi-helix",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Native multi-model team workflows for the Pi coding agent.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luisgui1757/helix.git"
  },
  "homepage": "https://github.com/luisgui1757/helix#readme",
  "bugs": {
    "url": "https://github.com/luisgui1757/helix/issues"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "multi-agent",
    "coding-agent"
  ],
  "type": "module",
  "files": [
    "README.md",
    "LICENSE",
    "extensions",
    "dispatch/config",
    "dispatch/kernel",
    "dispatch/lib",
    "dispatch/runtime",
    "dispatch/workflow",
    "NOTICE",
    "SECURITY.md",
    "docs/architecture.md",
    "docs/manual.md",
    "docs/providers.md",
    "docs/workflows.md",
    "tools/loop/helix-task-loop.mjs",
    "tools/research/helix-research.mjs"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.80.7 <0.81.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check:resources": "node tools/check-helix-resources.mjs",
    "check:docs-truth": "node tools/ci/docs-truth-check.mjs",
    "check:public-safety-diff": "node tools/ci/public-safety-diff-scan.mjs --mode diff",
    "check:no-live-egress": "node tools/ci/no-live-egress-check.mjs",
    "check:repository-policy": "node tools/repository-policy-check.mjs",
    "safeguards": "node scripts/apply-repo-safeguards.mjs",
    "safeguards:preflight": "node scripts/apply-repo-safeguards.mjs --preflight-only",
    "check:workflow-conformance": "node --test tests/workflow-v4-schema.test.mjs tests/workflow-kernel.test.mjs tests/helix-workflow-execution.test.mjs",
    "check:provider-contracts": "node --test tests/runtime-contract.test.mjs tests/provider-runtime-contract.test.mjs tests/dispatch-pi-agent-adapter.test.mjs tests/openrouter-audit-proxy.test.mjs",
    "check:package": "node tools/ci/package-check.mjs",
    "test:live:provider-certification": "node tools/providers/helix-provider-certify.mjs",
    "test": "node --test tests/*.test.mjs && bash tools/worktree/selftest.sh && bash tools/loop/selftest.sh"
  },
  "pi": {
    "extensions": [
      "./extensions/helix-fence.ts",
      "./extensions/helix-answer.ts",
      "./extensions/helix-command.ts"
    ]
  }
}
